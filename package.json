{
  "name": "@gafreax/csscrunch",
  "version": "1.5.0",
  "description": "Simple CSS Parser to tokenize CSS, merge rules, and optimize it",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "check": "biome check && vitest test --run && vitest bench --run && tsgo --noEmit",
    "prepublish": "pnpm run build",
    "build": "tsdown",
    "clean": "rimraf dist/",
    "start": "tsx src/launch.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prebuild": "pnpm run clean && biome check --write .",
    "prepare": "pnpm run build && husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:exclude-snap": "vitest run -t \"^(?!.*snapshot.*)$\"",
    "test:update-snap": "vitest run --update",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench --run"
  },
  "author": "Gabriele Fontana",
  "bin": {
    "csscrunch": "dist/launch.cjs"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/clean-css": "^4.2.11",
    "@types/node": "^25.9.5",
    "@typescript/native-preview": "7.0.0-dev.20260705.1",
    "@vitest/coverage-v8": "^4.1.10",
    "benny": "^3.7.1",
    "clean-css": "^5.3.3",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
